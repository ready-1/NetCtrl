# Syslog Environment Variables
# For local development and container configuration

# Syslog Server Configuration
SYSLOG_HOST=syslog
SYSLOG_PORT=514
SYSLOG_PROTOCOL=udp

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
RETENTION_DAYS=30

# Log Collection Settings
COLLECT_CONTAINER_LOGS=true
COLLECT_NGINX_LOGS=true
COLLECT_APPLICATION_LOGS=true

# Log Rotation
LOG_ROTATE_SIZE=10M
LOG_ROTATE_FILES=5

# Logging Output
# Options: files, elasticsearch, stdout
LOG_OUTPUT=files

# Storage Path
LOG_STORAGE_PATH=/var/log/cms
