# NGINX Environment Variables
# For local development and container configuration

# NGINX Server Configuration
NGINX_HOST=nginx
NGINX_PORT=80
NGINX_SERVER_NAME=localhost

# File Size Limits (for 2GB file uploads)
NGINX_MAX_BODY_SIZE=2048M
NGINX_CLIENT_MAX_BODY_SIZE=2048M
NGINX_PROXY_READ_TIMEOUT=300s
NGINX_PROXY_CONNECT_TIMEOUT=300s

# Proxy Configuration
API_HOST=backend
API_PORT=8000
FRONTEND_HOST=frontend
FRONTEND_PORT=3000

# SSL Configuration (optional)
SSL_ENABLED=false
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Logging Configuration
LOG_LEVEL=info
SYSLOG_HOST=syslog
SYSLOG_PORT=514
NGINX_ACCESS_LOG_FORMAT=json
