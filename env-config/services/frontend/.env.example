# Frontend (React) Environment Variables
# For local development and container configuration

# React App Configuration
REACT_APP_API_URL=http://localhost/api
REACT_APP_MATERIAL_UI_LOCAL_PATH=/static/material-ui
NODE_ENV=development
PORT=3000

# Container Settings
FRONTEND_HOST=frontend
FRONTEND_PORT=3000

# Local Package Repository (for air-gapped operation)
NPM_REGISTRY=http://localhost:4873

# Build Configuration
GENERATE_SOURCEMAP=false
REACT_APP_DISABLE_BROWSER_CONSOLE_IN_PROD=true

# Logging Configuration
REACT_APP_LOG_LEVEL=info
SYSLOG_HOST=syslog
SYSLOG_PORT=514
