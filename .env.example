# Database Configuration
POSTGRES_DB=netctrl
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django Settings
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change_this_to_a_secure_secret_key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,172.16.0.0,172.17.0.0,172.18.0.0,172.19.0.0,172.20.0.0,172.21.0.0,172.22.0.0,172.23.0.0,172.24.0.0,172.25.0.0,172.26.0.0,172.27.0.0,172.28.0.0,172.29.0.0,172.30.0.0,172.31.0.0,192.168.0.0

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Static and Media Files
STATIC_ROOT=/opt/static
MEDIA_ROOT=/opt/media
LOG_DIR=/opt/logs
